{
  "name": "Nextcloud",
  "logo": "https://upload.wikimedia.org/wikipedia/commons/6/60/Nextcloud_Logo.svg",
  "description": "Self-hosted productivity platform for file sync, sharing, and collaboration",
  "categories": [],
  "images": [],
  "configurations": [
    {
      "title": "NEXTCLOUD_ADMIN_USER",
      "schema": {
        "properties": {
          "value": {
            "type": "string",
            "title": "Admin username"
          }
        }
      },
      "default_value": {
        "value": "admin"
      },
      "destinations": [
        {
          "type": "env",
          "container": "nextcloud",
          "key": "NEXTCLOUD_ADMIN_USER"
        }
      ]
    },
    {
      "title": "NEXTCLOUD_ADMIN_PASSWORD",
      "schema": {
        "properties": {
          "value": {
            "type": "string",
            "title": "Admin password",
            "writeOnly": true,
            "minLength": 8
          }
        },
        "type": "object",
        "required": [
          "value"
        ]
      },
      "default_value": {
        "value": ""
      },
      "destinations": [
        {
          "type": "env",
          "container": "nextcloud",
          "key": "NEXTCLOUD_ADMIN_PASSWORD"
        }
      ]
    },
    {
      "title": "NEXTCLOUD_TRUSTED_DOMAINS",
      "schema": {
        "properties": {
          "value": {
            "type": "string",
            "title": "Trusted domains"
          }
        }
      },
      "default_value": {
        "value": "{{ instance_host }} localhost"
      },
      "destinations": [
        {
          "type": "env",
          "container": "nextcloud",
          "key": "NEXTCLOUD_TRUSTED_DOMAINS"
        }
      ]
    },
    {
      "title": "OVERWRITEPROTOCOL",
      "schema": {
        "properties": {
          "value": {
            "type": "string",
            "title": "OVERWRITEPROTOCOL"
          }
        }
      },
      "default_value": {
        "value": "https"
      },
      "destinations": [
        {
          "type": "env",
          "container": "nextcloud",
          "key": "OVERWRITEPROTOCOL"
        }
      ]
    },
    {
      "title": "OVERWRITEHOST",
      "schema": {
        "properties": {
          "value": {
            "type": "string",
            "title": "OVERWRITEHOST"
          }
        }
      },
      "default_value": {
        "value": "{{ instance_host }}"
      },
      "destinations": [
        {
          "type": "env",
          "container": "nextcloud",
          "key": "OVERWRITEHOST"
        }
      ]
    },
    {
      "title": "OVERWRITECLIURL",
      "schema": {
        "properties": {
          "value": {
            "type": "string",
            "title": "OVERWRITECLIURL"
          }
        }
      },
      "default_value": {
        "value": "{{ instance_url }}"
      },
      "destinations": [
        {
          "type": "env",
          "container": "nextcloud",
          "key": "OVERWRITECLIURL"
        }
      ]
    },
    {
      "title": "TRUSTED_PROXIES",
      "schema": {
        "properties": {
          "value": {
            "type": "string",
            "title": "TRUSTED_PROXIES"
          }
        }
      },
      "default_value": {
        "value": "{{ instance_host }}"
      },
      "destinations": [
        {
          "type": "env",
          "container": "nextcloud",
          "key": "TRUSTED_PROXIES"
        }
      ]
    },
    {
      "title": "SMTP",
      "schema": {
        "properties": {}
      },
      "default_value": {},
      "destinations": [
        { "type": "smtp", "container": "nextcloud", "key": "SMTP_HOST" },
        { "type": "smtp", "container": "nextcloud", "key": "SMTP_PORT" },
        { "type": "smtp", "container": "nextcloud", "key": "SMTP_NAME" },
        { "type": "smtp", "container": "nextcloud", "key": "SMTP_PASSWORD" },
        { "type": "smtp", "container": "nextcloud", "key": "MAIL_FROM_ADDRESS" },
        { "type": "smtp", "container": "nextcloud", "key": "MAIL_DOMAIN" },
        { "type": "smtp", "container": "nextcloud", "key": "SMTP_SECURE" }
      ]
    }
  ]
}