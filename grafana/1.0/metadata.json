{
  "name": "Grafana",
  "logo": "https://avatars.githubusercontent.com/u/7195757",
  "description": "Open-source analytics and interactive visualization dashboards",
  "categories": ["monitoring"],
  "images": [],
  "configurations": [
    {
      "title": "GF_SECURITY_ADMIN_PASSWORD",
      "schema": {
        "type": "object",
        "required": ["value"],
        "properties": {
          "value": {
            "type": "string",
            "title": "Admin password",
            "description": "Password for the 'admin' user you'll log in with. Choose your own.",
            "writeOnly": true,
            "minLength": 12
          }
        }
      },
      "default_value": { "value": "" },
      "destinations": [
        { "type": "env", "container": "grafana", "key": "GF_SECURITY_ADMIN_PASSWORD" }
      ]
    },
    {
      "title": "SMTP",
      "schema": { "properties": {} },
      "default_value": {},
      "destinations": [
        { "type": "smtp", "container": "grafana", "key": "GF_SMTP_ENABLED" },
        { "type": "smtp", "container": "grafana", "key": "GF_SMTP_HOST" },
        { "type": "smtp", "container": "grafana", "key": "GF_SMTP_USER" },
        { "type": "smtp", "container": "grafana", "key": "GF_SMTP_PASSWORD" },
        { "type": "smtp", "container": "grafana", "key": "GF_SMTP_FROM_ADDRESS" },
        { "type": "smtp", "container": "grafana", "key": "GF_SMTP_STARTTLS_POLICY" }
      ]
    }
  ]
}
