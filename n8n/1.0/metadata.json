{
  "name": "n8n",
  "logo": "https://avatars.githubusercontent.com/u/45487711",
  "description": "Workflow automation tool with native AI capabilities (fair-code)",
  "categories": ["automation"],
  "images": [],
  "configurations": [
    {
      "title": "N8N_ENCRYPTION_KEY",
      "schema": {
        "type": "object",
        "required": ["value"],
        "properties": {
          "value": {
            "type": "string",
            "title": "Encryption key",
            "description": "Encrypts stored credentials. Generated by the platform at instance creation.",
            "writeOnly": true,
            "minLength": 24,
            "format": "greffon-secret"
          }
        }
      },
      "default_value": { "value": "" },
      "destinations": [
        { "type": "env", "container": "n8n", "key": "N8N_ENCRYPTION_KEY" }
      ]
    },
    {
      "title": "SMTP",
      "schema": { "properties": {} },
      "default_value": {},
      "destinations": [
        { "type": "smtp", "container": "n8n", "key": "N8N_EMAIL_MODE" },
        { "type": "smtp", "container": "n8n", "key": "N8N_SMTP_HOST" },
        { "type": "smtp", "container": "n8n", "key": "N8N_SMTP_PORT" },
        { "type": "smtp", "container": "n8n", "key": "N8N_SMTP_USER" },
        { "type": "smtp", "container": "n8n", "key": "N8N_SMTP_PASS" },
        { "type": "smtp", "container": "n8n", "key": "N8N_SMTP_SENDER" },
        { "type": "smtp", "container": "n8n", "key": "N8N_SMTP_SSL" }
      ]
    }
  ]
}
