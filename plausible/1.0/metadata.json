{
  "name": "Plausible",
  "logo": "https://d33wubrfki0l68.cloudfront.net/46cd327ce5b9105d254284c1dbdaed390d0258c1/011e4/assets/images/icon/plausible_logo_sm.png",
  "description": "Lightweight and open-source web analytics",
  "categories": [],
  "images": [],
  "configurations": [
    {
      "title": "BASE_URL",
      "schema": {
        "properties": {
          "value": {
            "type": "string",
            "title": "Base URL"
          }
        }
      },
      "default_value": {
        "value": "{{ instance_url }}"
      },
      "destinations": [
        {
          "type": "env",
          "container": "plausible",
          "key": "BASE_URL"
        }
      ]
    },
    {
      "title": "SECRET_KEY_BASE",
      "schema": {
        "properties": {
          "value": {
            "type": "string",
            "title": "Secret key base",
            "description": "At least 64 characters. Generate one with: openssl rand -base64 48",
            "writeOnly": true,
            "minLength": 64
          }
        },
        "type": "object",
        "required": [
          "value"
        ]
      },
      "default_value": {
        "value": ""
      },
      "destinations": [
        {
          "type": "env",
          "container": "plausible",
          "key": "SECRET_KEY_BASE"
        }
      ]
    },
    {
      "title": "SMTP",
      "schema": {
        "properties": {}
      },
      "default_value": {},
      "destinations": [
        { "type": "smtp", "container": "plausible", "key": "SMTP_HOST_ADDR" },
        { "type": "smtp", "container": "plausible", "key": "SMTP_HOST_PORT" },
        { "type": "smtp", "container": "plausible", "key": "SMTP_USER_NAME" },
        { "type": "smtp", "container": "plausible", "key": "SMTP_USER_PWD" },
        { "type": "smtp", "container": "plausible", "key": "MAILER_EMAIL" },
        { "type": "smtp", "container": "plausible", "key": "SMTP_HOST_SSL_ENABLED" }
      ]
    }
  ]
}