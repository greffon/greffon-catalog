{
  "name": "Docs",
  "logo": "https://raw.githubusercontent.com/suitenumerique/docs/v5.2.1/src/frontend/apps/impress/public/assets/logo-suite-numerique.png",
  "description": "Collaborative document editor by La Suite numerique (DINUM). Self-contained demo: log in with demo / demo. Heavy app (about 10 services with a bundled identity provider), so the first boot pulls several GB and takes a few minutes before the login screen works. Change the demo credentials before exposing it publicly.",
  "categories": [
    "productivity",
    "collaboration"
  ],
  "images": [],
  "configurations": [
    {
      "title": "Gateway routing config",
      "schema": {
        "type": "object",
        "properties": {
          "file": {
            "type": "string",
            "format": "data-url",
            "title": "nginx gateway default.conf"
          }
        }
      },
      "default_value": {
        "file": "data:text/plain;base64,"
      },
      "destinations": [
        {
          "type": "file",
          "volume": "gateway_conf",
          "name": "default.conf"
        }
      ]
    },
    {
      "title": "Identity realm import",
      "schema": {
        "type": "object",
        "properties": {
          "file": {
            "type": "string",
            "format": "data-url",
            "title": "Keycloak realm.json"
          }
        }
      },
      "default_value": {
        "file": "data:application/json;base64,"
      },
      "destinations": [
        {
          "type": "file",
          "volume": "keycloak_import",
          "name": "realm.json"
        }
      ]
    },
    {
      "title": "Django secret key",
      "schema": {
        "type": "object",
        "required": [
          "value"
        ],
        "properties": {
          "value": {
            "type": "string",
            "title": "Django secret key",
            "writeOnly": true,
            "minLength": 50,
            "format": "greffon-secret"
          }
        }
      },
      "default_value": {
        "value": ""
      },
      "destinations": [
        {
          "type": "env",
          "container": "backend",
          "key": "DJANGO_SECRET_KEY"
        }
      ]
    },
    {
      "title": "Database password",
      "schema": {
        "type": "object",
        "required": [
          "value"
        ],
        "properties": {
          "value": {
            "type": "string",
            "title": "Database password",
            "writeOnly": true,
            "minLength": 24,
            "format": "greffon-secret"
          }
        }
      },
      "default_value": {
        "value": ""
      },
      "destinations": [
        {
          "type": "env",
          "container": "backend",
          "key": "DB_PASSWORD"
        },
        {
          "type": "env",
          "container": "celery",
          "key": "DB_PASSWORD"
        },
        {
          "type": "env",
          "container": "postgresql",
          "key": "POSTGRES_PASSWORD"
        }
      ]
    },
    {
