          "value": {
            "type": "string",
            "title": "Collaboration API key",
            "writeOnly": true,
            "minLength": 32,
            "format": "greffon-secret"
          }
        }
      },
      "default_value": {
        "value": ""
      },
      "destinations": [
        {
          "type": "env",
          "container": "backend",
          "key": "Y_PROVIDER_API_KEY"
        },
        {
          "type": "env",
          "container": "y-provider",
          "key": "Y_PROVIDER_API_KEY"
        }
      ]
    },
