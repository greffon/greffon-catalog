{
  "name": "Paperless-ngx",
  "logo": "https://avatars.githubusercontent.com/u/99562962",
  "description": "Scan, index, and archive your documents with OCR and full-text search",
  "categories": ["productivity"],
  "images": [],
  "configurations": [
    {
      "title": "PAPERLESS_SECRET_KEY",
      "schema": {
        "type": "object",
        "required": ["value"],
        "properties": {
          "value": {
            "type": "string",
            "title": "Secret key",
            "description": "Django secret key. Generated by the platform at instance creation.",
            "writeOnly": true,
            "minLength": 32,
            "format": "greffon-secret"
          }
        }
      },
      "default_value": { "value": "" },
      "destinations": [
        { "type": "env", "container": "paperless", "key": "PAPERLESS_SECRET_KEY" }
      ]
    },
    {
      "title": "PAPERLESS_ADMIN_PASSWORD",
      "schema": {
        "type": "object",
        "required": ["value"],
        "properties": {
          "value": {
            "type": "string",
            "title": "Admin password",
            "description": "Password for the 'admin' superuser you'll log in with. Choose your own.",
            "writeOnly": true,
            "minLength": 12
          }
        }
      },
      "default_value": { "value": "" },
      "destinations": [
        { "type": "env", "container": "paperless", "key": "PAPERLESS_ADMIN_PASSWORD" }
      ]
    },
    {
      "title": "SMTP",
      "schema": { "properties": {} },
      "default_value": {},
      "destinations": [
        { "type": "smtp", "container": "paperless", "key": "PAPERLESS_EMAIL_HOST" },
        { "type": "smtp", "container": "paperless", "key": "PAPERLESS_EMAIL_PORT" },
        { "type": "smtp", "container": "paperless", "key": "PAPERLESS_EMAIL_HOST_USER" },
        { "type": "smtp", "container": "paperless", "key": "PAPERLESS_EMAIL_HOST_PASSWORD" },
        { "type": "smtp", "container": "paperless", "key": "PAPERLESS_EMAIL_FROM" },
        { "type": "smtp", "container": "paperless", "key": "PAPERLESS_EMAIL_USE_TLS" },
        { "type": "smtp", "container": "paperless", "key": "PAPERLESS_EMAIL_USE_SSL" }
      ]
    }
  ]
}
