      "destinations": [
        {
          "type": "json",
          "volume": "user_data",
          "name": "config.json"
        }
      ]
    },
    {
      "title": "Strategy",
      "schema": {
        "type": "object",
        "required": [
          "file"
        ],
        "properties": {
          "file": {
            "type": "string",
            "format": "data-url",
            "title": "Strategy file (.py)"
          }
        }
      },
      "default_value": {
        "file": "data:text/x-python;base64,"
      },
      "destinations": [
        {
          "type": "file",
          "volume": "user_data_strategies",
          "name": "sample_strategy.py"
        }
      ]
    }
  ]
