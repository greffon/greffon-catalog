        "telegram": {
          "enabled": false,
          "token": "",
          "chat_id": ""
        },
        "api_server": {
          "enabled": true,
          "listen_ip_address": "0.0.0.0",
          "listen_port": 8080,
          "username": "",
          "password": ""
