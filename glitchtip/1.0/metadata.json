{
  "name": "GlitchTip",
  "logo": "https://gitlab.com/uploads/-/system/group/avatar/6475477/glitchtip_g.png",
  "description": "Open-source error tracking compatible with Sentry SDKs",
  "categories": [],
  "images": [],
  "configurations": [
    {
      "title": "SECRET_KEY",
      "schema": {
        "properties": {
          "value": { "type": "string", "title": "Secret key" }
        }
      },
      "default_value": { "value": "" },
      "destinations": [
        { "type": "env", "container": "glitchtip", "key": "SECRET_KEY" }
      ]
    },
    {
      "title": "GLITCHTIP_DOMAIN",
      "schema": {
        "properties": {
          "value": { "type": "string", "title": "GlitchTip domain URL" }
        }
      },
      "default_value": { "value": "" },
      "destinations": [
        { "type": "env", "container": "glitchtip", "key": "GLITCHTIP_DOMAIN" }
      ]
    },
    {
      "title": "DEFAULT_FROM_EMAIL",
      "schema": {
        "properties": {
          "value": { "type": "string", "title": "Default sender email" }
        }
      },
      "default_value": { "value": "" },
      "destinations": [
        { "type": "env", "container": "glitchtip", "key": "DEFAULT_FROM_EMAIL" }
      ]
    },
    {
      "title": "DJANGO_SUPERUSER_EMAIL",
      "schema": {
        "properties": {
          "value": { "type": "string", "title": "Admin email", "format": "email" }
        }
      },
      "default_value": { "value": "admin@greffon.local" },
      "destinations": [
        { "type": "env", "container": "glitchtip_seed", "key": "DJANGO_SUPERUSER_EMAIL" }
      ]
    },
    {
      "title": "DJANGO_SUPERUSER_PASSWORD",
      "schema": {
        "type": "object",
        "required": ["value"],
        "properties": {
          "value": { "type": "string", "title": "Admin password", "writeOnly": true, "minLength": 8 }
        }
      },
      "default_value": { "value": "" },
      "destinations": [
        { "type": "env", "container": "glitchtip_seed", "key": "DJANGO_SUPERUSER_PASSWORD" }
      ]
    }
  ]
}
