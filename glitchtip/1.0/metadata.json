{
  "name": "GlitchTip",
  "logo": "https://gitlab.com/uploads/-/system/group/avatar/6475477/glitchtip_g.png",
  "description": "Open-source error tracking compatible with Sentry SDKs",
  "categories": [],
  "images": [],
  "configurations": [
    {
      "title": "SECRET_KEY",
      "schema": {
        "type": "object",
        "required": [
          "value"
        ],
        "properties": {
          "value": {
            "type": "string",
            "title": "Django secret key (32+ chars)",
            "writeOnly": true,
            "minLength": 32
          }
        }
      },
      "default_value": {
        "value": ""
      },
      "destinations": [
        {
          "type": "env",
          "container": "glitchtip",
          "key": "SECRET_KEY"
        }
      ]
    },
    {
      "title": "GLITCHTIP_DOMAIN",
      "schema": {
        "properties": {
          "value": {
            "type": "string",
            "title": "GlitchTip domain URL"
          }
        }
      },
      "default_value": {
        "value": "{{ instance_url }}"
      },
      "destinations": [
        {
          "type": "env",
          "container": "glitchtip",
          "key": "GLITCHTIP_DOMAIN"
        },
        {
          "type": "env",
          "container": "glitchtip",
          "key": "GLITCHTIP_URL"
        },
        {
          "type": "env",
          "container": "glitchtip",
          "key": "CSRF_TRUSTED_ORIGINS"
        }
      ]
    },
    {
      "title": "DEFAULT_FROM_EMAIL",
      "schema": {
        "properties": {
          "value": {
            "type": "string",
            "title": "Default sender email"
          }
        }
      },
      "default_value": {
        "value": ""
      },
      "destinations": [
        {
          "type": "env",
          "container": "glitchtip",
          "key": "DEFAULT_FROM_EMAIL"
        }
      ]
    },
    {
      "title": "DJANGO_SUPERUSER_EMAIL",
      "schema": {
        "properties": {
          "value": {
            "type": "string",
            "title": "Admin email",
            "format": "email"
          }
        }
      },
      "default_value": {
        "value": "admin@greffon.io"
      },
      "destinations": [
        {
          "type": "env",
          "container": "glitchtip_seed",
          "key": "DJANGO_SUPERUSER_EMAIL"
        }
      ]
    },
    {
      "title": "DJANGO_SUPERUSER_PASSWORD",
      "schema": {
        "type": "object",
        "required": [
          "value"
        ],
        "properties": {
          "value": {
            "type": "string",
            "title": "Admin password",
            "writeOnly": true,
            "minLength": 8
          }
        }
      },
      "default_value": {
        "value": ""
      },
      "destinations": [
        {
          "type": "env",
          "container": "glitchtip_seed",
          "key": "DJANGO_SUPERUSER_PASSWORD"
        }
      ]
    },
    {
      "title": "SMTP",
      "schema": {
        "properties": {}
      },
      "default_value": {},
      "destinations": [
        { "type": "smtp", "container": "glitchtip",        "key": "EMAIL_URL" },
        { "type": "smtp", "container": "glitchtip_worker", "key": "EMAIL_URL" }
      ]
    }
  ]
}