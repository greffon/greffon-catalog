    {
      "title": "ADMIN_PASSWORD_EXAMPLE",
      "schema": {
        "type": "object",
        "required": ["value"],
        "properties": {
          "value": {
            "type": "string",
            "title": "Admin password",
            "writeOnly": true,
            "minLength": 8
          }
        }
      },
      "default_value": { "value": "" },
      "destinations": [
        { "type": "env", "container": "app", "key": "ADMIN_PASSWORD" }
      ]
    }
