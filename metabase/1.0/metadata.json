{
  "name": "Metabase",
  "logo": "https://avatars.githubusercontent.com/u/10520629",
  "description": "Open-source business intelligence — dashboards, questions, and visualizations over your data",
  "categories": ["analytics"],
  "images": [],
  "configurations": [
    {
      "title": "MB_SITE_URL",
      "schema": {
        "properties": { "value": { "type": "string", "title": "Public URL" } }
      },
      "default_value": { "value": "{{ instance_url }}" },
      "destinations": [
        { "type": "env", "container": "metabase", "key": "MB_SITE_URL" }
      ]
    },
    {
      "title": "SMTP",
      "schema": { "properties": {} },
      "default_value": {},
      "destinations": [
        { "type": "smtp", "container": "metabase", "key": "MB_EMAIL_SMTP_HOST" },
        { "type": "smtp", "container": "metabase", "key": "MB_EMAIL_SMTP_PORT" },
        { "type": "smtp", "container": "metabase", "key": "MB_EMAIL_SMTP_USERNAME" },
        { "type": "smtp", "container": "metabase", "key": "MB_EMAIL_SMTP_PASSWORD" },
        { "type": "smtp", "container": "metabase", "key": "MB_EMAIL_FROM_ADDRESS" },
        { "type": "smtp", "container": "metabase", "key": "MB_EMAIL_SMTP_SECURITY" }
      ]
    }
  ]
}
