{
  "name": "Activepieces",
  "logo": "https://avatars.githubusercontent.com/u/99494700",
  "description": "Open-source no-code business automation and AI workflow builder (Zapier alternative)",
  "categories": ["automation"],
  "images": [],
  "configurations": [
    {
      "title": "AP_FRONTEND_URL",
      "schema": {
        "properties": {
          "value": { "type": "string", "title": "Public URL" }
        }
      },
      "default_value": { "value": "{{ instance_url }}" },
      "destinations": [
        { "type": "env", "container": "activepieces", "key": "AP_FRONTEND_URL" }
      ]
    },
    {
      "title": "AP_ENCRYPTION_KEY",
      "schema": {
        "type": "object",
        "required": ["value"],
        "properties": {
          "value": {
            "type": "string",
            "title": "Encryption key",
            "description": "Encrypts stored connection credentials. Generated by the platform at instance creation.",
            "writeOnly": true,
            "minLength": 32,
            "format": "greffon-secret"
          }
        }
      },
      "default_value": { "value": "" },
      "destinations": [
        { "type": "env", "container": "activepieces", "key": "AP_ENCRYPTION_KEY" }
      ]
    },
    {
      "title": "AP_JWT_SECRET",
      "schema": {
        "type": "object",
        "required": ["value"],
        "properties": {
          "value": {
            "type": "string",
            "title": "JWT secret",
            "description": "Signs auth tokens. Generated by the platform at instance creation.",
            "writeOnly": true,
            "minLength": 32,
            "format": "greffon-secret"
          }
        }
      },
      "default_value": { "value": "" },
      "destinations": [
        { "type": "env", "container": "activepieces", "key": "AP_JWT_SECRET" }
      ]
    },
    {
      "title": "SMTP",
      "schema": { "properties": {} },
      "default_value": {},
      "destinations": [
        { "type": "smtp", "container": "activepieces", "key": "AP_SMTP_HOST" },
        { "type": "smtp", "container": "activepieces", "key": "AP_SMTP_PORT" },
        { "type": "smtp", "container": "activepieces", "key": "AP_SMTP_USERNAME" },
        { "type": "smtp", "container": "activepieces", "key": "AP_SMTP_PASSWORD" },
        { "type": "smtp", "container": "activepieces", "key": "AP_SMTP_SENDER_EMAIL" },
        { "type": "smtp", "container": "activepieces", "key": "AP_SMTP_USE_SSL" }
      ]
    }
  ]
}
