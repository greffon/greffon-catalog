{
  "name": "Vikunja",
  "logo": "https://avatars.githubusercontent.com/u/97856433",
  "description": "Self-hosted to-do and project management app",
  "categories": ["productivity"],
  "images": [],
  "configurations": [
    {
      "title": "VIKUNJA_SERVICE_PUBLICURL",
      "schema": {
        "properties": {
          "value": {
            "type": "string",
            "title": "Public URL"
          }
        }
      },
      "default_value": { "value": "{{ instance_url }}" },
      "destinations": [
        { "type": "env", "container": "vikunja", "key": "VIKUNJA_SERVICE_PUBLICURL" }
      ]
    },
    {
      "title": "VIKUNJA_SERVICE_SECRET",
      "schema": {
        "type": "object",
        "properties": {
          "value": {
            "type": "string",
            "title": "Service secret",
            "description": "Signs auth tokens. Generated by the platform at instance creation.",
            "writeOnly": true,
            "minLength": 32,
            "format": "greffon-secret"
          }
        },
        "required": ["value"]
      },
      "default_value": { "value": "" },
      "destinations": [
        { "type": "env", "container": "vikunja", "key": "VIKUNJA_SERVICE_SECRET" }
      ]
    }
  ]
}
