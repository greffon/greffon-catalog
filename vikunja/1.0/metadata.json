{
  "name": "Vikunja",
  "logo": "https://raw.githubusercontent.com/go-vikunja/vikunja/main/frontend/public/images/icons/apple-touch-icon-180x180.png",
  "description": "Self-hosted to-do and project management app",
  "categories": ["productivity"],
  "images": [],
  "configurations": [
    {
      "title": "VIKUNJA_SERVICE_PUBLICURL",
      "schema": {
        "properties": {
          "value": {
            "type": "string",
            "title": "Public URL"
          }
        },
        "x-greffon-visibility": "advanced"
      },
      "default_value": { "value": "{{ instance_url }}" },
      "destinations": [
        { "type": "env", "container": "vikunja", "key": "VIKUNJA_SERVICE_PUBLICURL" }
      ]
    },
    {
      "title": "VIKUNJA_SERVICE_SECRET",
      "schema": {
        "type": "object",
        "properties": {
          "value": {
            "type": "string",
            "title": "Service secret",
            "description": "Signs auth tokens. Generated by the platform at instance creation.",
            "writeOnly": true,
            "minLength": 32,
            "format": "greffon-secret"
          }
        },
        "required": ["value"],
        "x-greffon-visibility": "advanced"
      },
      "default_value": { "value": "" },
      "destinations": [
        { "type": "env", "container": "vikunja", "key": "VIKUNJA_SERVICE_SECRET" }
      ]
    },
    {
      "title": "SMTP",
      "schema": { "properties": {} },
      "default_value": {},
      "destinations": [
        { "type": "smtp", "container": "vikunja", "key": "VIKUNJA_MAILER_ENABLED" },
        { "type": "smtp", "container": "vikunja", "key": "VIKUNJA_MAILER_HOST" },
        { "type": "smtp", "container": "vikunja", "key": "VIKUNJA_MAILER_PORT" },
        { "type": "smtp", "container": "vikunja", "key": "VIKUNJA_MAILER_USERNAME" },
        { "type": "smtp", "container": "vikunja", "key": "VIKUNJA_MAILER_PASSWORD" },
        { "type": "smtp", "container": "vikunja", "key": "VIKUNJA_MAILER_FROMEMAIL" },
        { "type": "smtp", "container": "vikunja", "key": "VIKUNJA_MAILER_FORCESSL" }
      ]
    }
  ]
}
