{
  "name": "Visio",
  "logo": "https://raw.githubusercontent.com/suitenumerique/meet/v1.19.0/src/frontend/public/android-chrome-512x512.png",
  "description": "Video conferencing by La Suite numerique (DINUM), built on LiveKit. Self-contained demo: log in with demo / demo (or create an account). Heavy app (~10 services + a WebRTC media server); first boot pulls several GB and takes a few minutes. Media uses a UDP port published directly on the host. Change the demo credentials before exposing it.",
  "categories": [
    "productivity",
    "collaboration"
  ],
  "images": [],
  "ports": [
    {
      "name": "livekit_7882",
      "exposure_tier": "l4",
      "protocol": "udp",
      "same_port": true
    }
  ],
  "configurations": [
    {
      "title": "Gateway routing config",
      "schema": {
        "type": "object",
        "properties": {
          "file": {
            "type": "string",
            "format": "data-url",
            "title": "nginx gateway default.conf"
          }
        },
        "x-greffon-visibility": "hidden"
      },
      "default_value": {
        "file": "data:text/plain;base64,"
      },
      "destinations": [
        {
          "type": "file",
          "volume": "gateway_conf",
          "name": "default.conf"
        }
      ]
    },
    {
      "title": "Identity realm import",
      "schema": {
        "type": "object",
        "properties": {
          "file": {
            "type": "string",
            "format": "data-url",
            "title": "Keycloak realm.json"
          }
        },
        "x-greffon-visibility": "hidden"
      },
      "default_value": {
        "file": "data:application/json;base64,"
      },
      "destinations": [
        {
          "type": "file",
          "volume": "keycloak_import",
          "name": "realm.json",
          "x-greffon-render": true
        }
      ]
    },
    {
      "title": "LiveKit config",
      "schema": {
        "type": "object",
        "properties": {
          "file": {
            "type": "string",
            "format": "data-url",
            "title": "livekit.yaml"
          }
        },
        "x-greffon-visibility": "hidden"
      },
      "default_value": {
        "file": "data:text/plain;base64,"
      },
      "destinations": [
        {
          "type": "file",
          "volume": "livekit_conf",
          "name": "livekit.yaml",
          "x-greffon-render": true
        }
      ]
    },
    {
      "title": "Django secret key",
      "schema": {
        "type": "object",
        "required": [
          "value"
        ],
        "properties": {
          "value": {
            "type": "string",
            "title": "Django secret key",
            "writeOnly": true,
            "minLength": 50,
            "format": "greffon-secret"
          }
        },
        "x-greffon-visibility": "advanced"
      },
      "default_value": {
        "value": ""
      },
      "destinations": [
        {
          "type": "env",
          "container": "backend",
          "key": "DJANGO_SECRET_KEY"
        }
      ]
    },
    {
      "title": "Database password",
      "schema": {
        "type": "object",
        "required": [
          "value"
        ],
        "properties": {
          "value": {
            "type": "string",
            "title": "Database password",
            "writeOnly": true,
            "minLength": 24,
            "format": "greffon-secret"
          }
        },
        "x-greffon-visibility": "advanced"
      },
      "default_value": {
        "value": ""
      },
      "destinations": [
        {
          "type": "env",
          "container": "backend",
          "key": "DB_PASSWORD"
        },
        {
          "type": "env",
          "container": "celery",
          "key": "DB_PASSWORD"
        },
        {
          "type": "env",
          "container": "postgresql",
          "key": "POSTGRES_PASSWORD"
        }
      ]
    },
    {
      "title": "Object storage access key",
      "schema": {
        "type": "object",
        "required": [
          "value"
        ],
        "properties": {
          "value": {
            "type": "string",
            "title": "Object storage access key",
            "writeOnly": true,
            "minLength": 20,
            "format": "greffon-secret-alnum"
          }
        },
        "x-greffon-visibility": "advanced"
      },
      "default_value": {
        "value": ""
      },
      "destinations": [
        {
          "type": "env",
          "container": "minio",
          "key": "MINIO_ROOT_USER"
        },
        {
          "type": "env",
          "container": "createbuckets",
          "key": "MINIO_ROOT_USER"
        },
        {
          "type": "env",
          "container": "backend",
          "key": "AWS_S3_ACCESS_KEY_ID"
        },
        {
          "type": "env",
          "container": "celery",
          "key": "AWS_S3_ACCESS_KEY_ID"
        }
      ]
    },
    {
      "title": "Object storage secret key",
      "schema": {
        "type": "object",
        "required": [
          "value"
        ],
        "properties": {
          "value": {
            "type": "string",
            "title": "Object storage secret key",
            "writeOnly": true,
            "minLength": 32,
            "format": "greffon-secret"
          }
        },
        "x-greffon-visibility": "advanced"
      },
      "default_value": {
        "value": ""
      },
      "destinations": [
        {
          "type": "env",
          "container": "minio",
          "key": "MINIO_ROOT_PASSWORD"
        },
        {
          "type": "env",
          "container": "createbuckets",
          "key": "MINIO_ROOT_PASSWORD"
        },
        {
          "type": "env",
          "container": "backend",
          "key": "AWS_S3_SECRET_ACCESS_KEY"
        },
        {
          "type": "env",
          "container": "celery",
          "key": "AWS_S3_SECRET_ACCESS_KEY"
        }
      ]
    },
    {
      "title": "LiveKit API secret",
      "schema": {
        "type": "object",
        "required": [
          "value"
        ],
        "properties": {
          "value": {
            "type": "string",
            "title": "LiveKit API secret",
            "writeOnly": true,
            "minLength": 32,
            "format": "greffon-secret"
          }
        },
        "x-greffon-visibility": "advanced"
      },
      "default_value": {
        "value": ""
      },
      "destinations": [
        {
          "type": "env",
          "container": "backend",
          "key": "LIVEKIT_API_SECRET"
        },
        {
          "type": "env",
          "container": "celery",
          "key": "LIVEKIT_API_SECRET"
        }
      ]
    },
    {
      "title": "Identity admin password",
      "schema": {
        "type": "object",
        "required": [
          "value"
        ],
        "properties": {
          "value": {
            "type": "string",
            "title": "Identity admin password",
            "writeOnly": true,
            "minLength": 16,
            "format": "greffon-secret"
          }
        },
        "x-greffon-visibility": "advanced"
      },
      "default_value": {
        "value": ""
      },
      "destinations": [
        {
          "type": "env",
          "container": "keycloak",
          "key": "KC_BOOTSTRAP_ADMIN_PASSWORD"
        }
      ]
    },
    {
      "title": "OIDC client secret",
      "schema": {
        "type": "object",
        "required": [
          "value"
        ],
        "properties": {
          "value": {
            "type": "string",
            "title": "OIDC client secret",
            "writeOnly": true,
            "minLength": 32,
            "format": "greffon-secret"
          }
        },
        "x-greffon-visibility": "advanced"
      },
      "default_value": {
        "value": ""
      },
      "destinations": [
        {
          "type": "env",
          "container": "backend",
          "key": "OIDC_RP_CLIENT_SECRET"
        }
      ]
    },
    {
      "title": "SMTP",
      "schema": {
        "type": "object",
        "properties": {}
      },
      "default_value": {},
      "destinations": [
        {
          "type": "smtp",
          "container": "backend",
          "key": "DJANGO_EMAIL_HOST"
        },
        {
          "type": "smtp",
          "container": "backend",
          "key": "DJANGO_EMAIL_PORT"
        },
        {
          "type": "smtp",
          "container": "backend",
          "key": "DJANGO_EMAIL_HOST_USER"
        },
        {
          "type": "smtp",
          "container": "backend",
          "key": "DJANGO_EMAIL_HOST_PASSWORD"
        },
        {
          "type": "smtp",
          "container": "backend",
          "key": "DJANGO_EMAIL_FROM"
        },
        {
          "type": "smtp",
          "container": "backend",
          "key": "DJANGO_EMAIL_USE_TLS"
        }
      ]
    }
  ]
}
